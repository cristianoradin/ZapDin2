# ============================================================
#  ZapDin MONITOR — Configuração de Produção
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o .env real no git.
# ============================================================

PORT=5000
DATABASE_URL=data/monitor.db

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_VALOR_SECRETO_ALEATORIO

# ── Comunicação Monitor → App ─────────────────────────────────────────────────
# URL do App de envio instalado no cliente (para sincronização de usuários)
# Em produção: http://IP_DA_MAQUINA_DO_CLIENTE:4000
APP_URL=http://localhost:4000

# Token compartilhado Monitor ↔ App para sincronização de usuários
# Deve ser IDÊNTICO ao MONITOR_CLIENT_TOKEN do app/.env do cliente
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SYNC_TOKEN=

# ── URL pública deste Monitor ─────────────────────────────────────────────────
# Endereço que o App usará para se comunicar após a ativação
# Em produção: http://SEU_IP_OU_DOMINIO:5000
# Se usar domínio com SSL: https://monitor.seudominio.com.br
MONITOR_PUBLIC_URL=http://SEU_SERVIDOR:5000

# ── Versão atual do App distribuído ──────────────────────────────────────────
CURRENT_APP_VERSION=1.0.0
